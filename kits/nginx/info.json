{
  "name": "Nginx",
  "desc": "TLS 1.3 / HTTP/3 gateway — reverse proxy to all backends",
  "depends": [
    "core"
  ],
  "docker": {"service": "nginx", "container": "gx"},
  "compose": "hub",
  "provides": [
    {
      "dir": ".gx/conf.d",
      "accepts": ["site"],
      "file": "site",
      "check": false,
      "layout": {
        "files": ["zone","upstream","server","location"],
        "ext": "conf",
        "zone": "zones",
        "upstream": "upstreams",
        "server": "servers",
        "location": "locations"
      }
    },
    {
      "dir": ".wr",
      "accepts": ["webroot"],
      "file": "webroot",
      "check": false
    }
  ],
  "store": {
    "dir": ".gx",
    "items": {
      "nginx.conf": "hardlink",
      "mime.types": "hardlink",
      "conf.d": {
        "method": "mkdir",
        "subs": [
          "zones",
          "upstreams",
          "servers",
          "locations"
        ]
      }
    }
  }
}
