# G41KiTS — Environment Configuration
# Copy to .env and edit before running ./g41.sh init

# ── Cloudflare API (consumed by: acme) ──────────
CF_Key=<your_cloudflare_api_key>
CF_Email=<your_cloudflare_email>
ACME_EMAIL=<your_email>

# ── Domain (consumed by: acme, nginx, home) ────
G41_DOMAIN=<your_domain>
# Extra domains for SSL cert SAN (space-separated)
G41_EXTRA_DOMAINS="<extra_domain1> <extra_domain2>"

# ── KITS system ─────────────────────────────────
# Reserved dependency keyword
G41_CORE=core
# Default numeric prefix for nginx site configs
G41_PREFIX=999

# ── Redis (consumed by: redis, api) ─────────────
REDIS_PASSWORD=<generate_a_strong_password>
# Secret for POST /admin/reload hot-reload endpoint
RELOAD_SECRET=<generate_a_strong_secret>

# ── Installed modules (auto-managed by g41.sh) ──
G41_KITS=""
# ── Attic Nix Cache (consumed by: attic) ──
ATTIC_TOKEN_SECRET=<generate_with: atticd --database /data/attic.db generate-keypair>
